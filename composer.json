{
    "name": "ryanbeiden/artifactsmmo-php",
    "version": "1.0.0",
    "description": "A type-safe PHP SDK for the Artifacts MMO game API.",
    "keywords": ["artifacts-mmo", "sdk", "api-client", "php", "openapi"],
    "homepage": "https://github.com/ryanbeiden/artifactsmmo-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Ryan Beiden",
            "email": "ryanbeiden@pm.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "ArtifactsMmo\\" : ""
        }
    }
}
